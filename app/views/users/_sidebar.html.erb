<h2>User info</h2>

<div class="mb-2 border-bottom">
  <% if user.profile_image.attached? %>
    <%= image_tag user.profile_image, size: "100x100" %>
  <% else %>
    <%= image_tag "default-image.jpg", size: "100x100" %>
  <% end %>
</div>

<div class="d-flex border-bottom py-2">
  <strong class="me-3">name</strong>
  <span class="ms-auto"><strong><%= user.name %></strong></span>
</div>

<div class="d-flex py-2">
  <strong class="me-3">introduction</strong>
  <span><strong><%= user.introduction %></strong></span>
</div>

<div class="d-flex border-bottom py-2">
  <strong class="me-3">follows</strong>
  <span class="ms-auto">
    <strong>
      <%= link_to user.followings.count, follows_user_path(user), class: "text-decoration-none" %>
    </strong>
  </span>
</div>

<div class="d-flex border-bottom py-2">
  <strong class="me-3">followers</strong>
  <span class="ms-auto">
    <strong>
      <%= link_to user.followers.count, followers_user_path(user), class: "text-decoration-none" %>
    </strong>
  </span>
</div>

<% if user == Current.user %>
  <%= link_to edit_user_path(user), class: "btn btn-outline-secondary w-100 mt-5" do %>
    <i class="fa-solid fa-user-gear"></i>
  <% end %>
<% else %>
  <% if Current.user.following?(user) %>
    <%= link_to "フォロー外す",
        relationship_path(Current.user.active_relationships.find_by(followed_id: user.id)),
        data: { turbo_method: :delete },
        class: "btn btn-info text-white w-100 mt-5" %>
  <% else %>
    <%= link_to "フォローする",
        relationships_path(relationship: { followed_id: user.id }),
        data: { turbo_method: :post },
        class: "btn btn-success text-white w-100 mt-5" %>
  <% end %>
<% end %>

<% if book&.errors&.any? %>
  <div class="text-danger">
    <h2><%= pluralize(book.errors.count, "error") %> prohibited this book from being saved:</h2>
    <ul>
      <% book.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<h2 class="mt-3">New book</h2>

<%= form_with model: book do |f| %>
  <p class="mb-1">title</p>
  <%= f.text_field :title %>

  <p class="mb-1 mt-2">Opinion</p>
  <%= f.text_area :body %>

  <%= f.submit "Create Book", class: "btn btn-success" %>
<% end %>