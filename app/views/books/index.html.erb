<div class="container">
  <div class="row">
    <div class="col-md-3">
      <%= render "users/sidebar", user: @user, book: @book %>
    </div>

    <div class="col-md-8 offset-md-1">
      <h2 class="border-bottom">Books</h2>

      <table class="table">
        <thead>
          <tr>
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
            <th></th>
            <th></th>
          </tr>
        </thead>

        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  <% if book.user.profile_image.attached? %>
                    <%= image_tag book.user.profile_image, size: "80x80" %>
                  <% else %>
                    <%= image_tag "default-image.jpg", size: "80x80" %>
                  <% end %>
                <% end %>
              </td>

              <td>
                <%= link_to book.title, book_path(book) %>
              </td>

              <td>
                <%= book.body %>
              </td>

              <td>
                <div id="favorite_btn_<%= book.id %>">
                  <%= render "favorites/favorite", book: book %>
                </div>
              </td>

              <td>
                コメント数: <%= book.book_comments.count %>
              </td>

            </tr>
          <% end %>
        </tbody>
      </table>
        <h2>7日間の投稿数</h2>
  
        <table class="table table-bordered">
        <thead>
          <tr>
            <% @last_7_days_book_counts.each do |data| %>
              <th><%= data[:label] %></th>
            <% end %>
          </tr>
        </thead>

        <tbody>
          <tr>
            <% @last_7_days_book_counts.each do |data| %>
              <td><%= data[:count] %></td>
            <% end %>
          </tr>
        </tbody>
      </table>

      <div style="width: 200%, max-width: 700px;">
        <canvas
          id="last7DaysChart"
          data-labels="<%= @chart_labels.to_json %>"
          data-counts="<%= @chart_counts.to_json %>" >
        </canvas>
      </div>
    </div>
  </div>
</div>